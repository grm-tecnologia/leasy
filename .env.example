# ─── App ──────────────────────────────────────────────────────────
NODE_ENV=production
APP_URL=https://leasy.app.br
PORT=3000

# ─── Database (TiDB or MySQL) ────────────────────────────────────
DATABASE_URL=mysql://user:password@host:port/database?ssl={"rejectUnauthorized":true}

# ─── Auth ─────────────────────────────────────────────────────────
JWT_SECRET=your-random-secret-here
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
ADMIN_EMAIL=kaio@leasy.app.br

# ─── OpenAI (for AI column mapping) ──────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ─── Mercado Pago ────────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=APP_USR-...
VITE_MERCADOPAGO_PUBLIC_KEY=APP_USR-...
MP_WEBHOOK_SECRET=your-webhook-secret

# ─── Resend (Transactional Emails) ───────────────────────────────
RESEND_API_KEY=re_...

# ─── Redis (BullMQ background jobs) ─────────────────────────────
REDIS_URL=redis://127.0.0.1:6379

# ─── LLM Rate Limiting ──────────────────────────────────────────
LLM_RATE_LIMIT_PER_USER_PER_MIN=5
LLM_RATE_LIMIT_GLOBAL_PER_MIN=60
LLM_DAILY_BUDGET_USD=50

# ─── Storage ─────────────────────────────────────────────────────
# Mode: "local" for local file storage, "s3" for AWS S3
STORAGE_MODE=local
STORAGE_PATH=/var/www/leasy/storage
STORAGE_URL=https://leasy.app.br/storage

# S3 (only needed if STORAGE_MODE=s3)
# S3_BUCKET=leasy-storage
# S3_REGION=us-east-1
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key

# ─── Docker MySQL (used by docker-compose) ──────────────────────
MYSQL_ROOT_PASSWORD=root_secret
MYSQL_DATABASE=leasy
MYSQL_USER=leasy
MYSQL_PASSWORD=leasy_secret

# ─── Legacy (admin auto-promotion) ───────────────────────────────
OWNER_OPEN_ID=google_admin-google-id-here
